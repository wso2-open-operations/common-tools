# Anthropic API key for AI insights. If unset, ai_insights returns "unavailable".
ANTHROPIC_API_KEY=

# Authentication

# Require a valid Asgardeo Bearer JWT on /analyze/jobs (POST + GET). Default: true.
# AUTH_ENABLED=false makes the analyze endpoints PUBLIC — local testing only.
AUTH_ENABLED=

# Asgardeo tenant base URL, e.g. https://api.asgardeo.io/t/<org>.
# JWKS + issuer derived (<base>/oauth2/jwks, <base>/oauth2/token) unless overridden below.
ASGARDEO_BASE_URL=

# Explicit overrides for the values derived from ASGARDEO_BASE_URL (optional).
JWT_JWKS_URL=
JWT_ISSUER=

# Expected audience (aud) claim; set to the app's client ID. Empty = aud not checked.
JWT_AUDIENCE=

# Logging

# slog level: DEBUG, INFO, WARN, ERROR. Default: INFO.
LOG_LEVEL=

# Session log file. Logs always print to the console (colorized on a TTY) and are
# mirrored to this file (plain text). Default: logs/tdat-session-<timestamp>.log.
# Set an explicit path to pin it, or off/none/- to disable file logging.
LOG_FILE=

# HTTP server

# Listen port. Default: 8080.
PORT=

# Public base URL logged at startup for click-to-test. Default: http://localhost:${PORT}.
PUBLIC_URL=

# Server timeouts (Go duration). Defaults: 30s, 10m, 10m, 5m.
# ReadTimeout/WriteTimeout bound the full multipart upload window — keep generous for ~100MB uploads on real uplinks.
READ_HEADER_TIMEOUT=
READ_TIMEOUT=
WRITE_TIMEOUT=
IDLE_TIMEOUT=

# File paths

# Grule rules file. Default: ./internal/rules/rules.grl.
RULES_PATH=

# Thread-pool YAML. Default: ./config/thread_pools.yaml.
THREAD_POOLS_PATH=

# CORS

# Comma-separated.
# Defaults: "http://localhost:5173", "GET,POST,OPTIONS", "Accept,Content-Type,Content-Length,Accept-Encoding,X-CSRF-Token,Authorization".
# In production, set CORS_ALLOWED_ORIGINS to your frontend origin(s) — do NOT use "*" with no backend auth.
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_METHODS=
CORS_ALLOWED_HEADERS=

# rs/cors debug logging. Default: false.
CORS_DEBUG=

# Job store

# Max multipart upload size. Accepts B/K/KB/KiB/M/MB/MiB/G/GB/GiB. Default: 100MB.
# thread_usages columns are mapped by header (TID/LWP/SPID, %CPU/PCPU/CPU; extras ignored) or fall back to PID TID %CPU TIME. TID may be decimal or hex.
MAX_UPLOAD_BYTES=

# Per-file decompressed-size cap for gzip uploads. Same units as MAX_UPLOAD_BYTES. Default: 2x MAX_UPLOAD_BYTES (200MB).
# The frontend gzips each file; the backend inflates parts under this cap to bound decompression-bomb memory.
MAX_DECOMPRESSED_BYTES=

# Total decompressed-size cap across all parts in one request. Same units. Default: 2x MAX_DECOMPRESSED_BYTES (400MB).
# Bounds whole-request memory so many parts can't sum into an OOM even when each clears the per-file cap.
MAX_TOTAL_DECOMPRESSED_BYTES=

# Terminal job retention (Go duration). Default: 1h.
JOB_TTL=

# Max terminal jobs in memory (pending/running never evicted). Default: 200.
JOB_STORE_MAX_SIZE=

# Eviction sweep interval (Go duration). Default: 1m.
JOB_JANITOR_TICK=

# Overall deadline for one analysis job (Go duration). Default: 2m.
# When exceeded, the job is marked failed and the inner pipeline aborts at its next checkpoint.
JOB_TIMEOUT=

# Rate limiting

# Max concurrent in-flight analysis jobs (counting semaphore). Excess POSTs get 429. Default: 10.
MAX_CONCURRENT_JOBS=

# Per-IP token bucket on POST /analyze/jobs. RPS is steady-state requests/second; BURST is max immediate. Defaults: 0.5, 5.
RATE_LIMIT_RPS=
RATE_LIMIT_BURST=

# Visitor TTL (forget idle IPs) and janitor sweep interval (Go duration). Defaults: 1h, 5m.
RATE_LIMIT_VISITOR_TTL=
RATE_LIMIT_JANITOR_TICK=
