# Anthropic API key for AI insights. If unset, ai_insights returns "unavailable".
ANTHROPIC_API_KEY=

# Logging

# slog level: DEBUG, INFO, WARN, ERROR. Default: INFO.
LOG_LEVEL=

# HTTP server

# Listen port. Default: 8080.
PORT=

# Public base URL logged at startup for click-to-test. Default: http://localhost:${PORT}.
PUBLIC_URL=

# Server timeouts (Go duration). Defaults: 30s, 10m, 10m, 5m.
# ReadTimeout/WriteTimeout bound the full multipart upload window — keep generous for ~100MB uploads on real uplinks.
READ_HEADER_TIMEOUT=
READ_TIMEOUT=
WRITE_TIMEOUT=
IDLE_TIMEOUT=

# File paths

# Grule rules file. Default: ./internal/rules/rules.grl.
RULES_PATH=

# Thread-pool YAML. Default: ./config/thread_pools.yaml.
THREAD_POOLS_PATH=

# CORS

# Comma-separated. 
# Defaults: "*", "GET,POST,OPTIONS,PUT,DELETE", "Accept,Content-Type,Content-Length,Accept-Encoding,X-CSRF-Token,Authorization".
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_METHODS=
CORS_ALLOWED_HEADERS=

# rs/cors debug logging. Default: false.
CORS_DEBUG=

# Job store

# Max multipart upload size. Accepts B/K/KB/KiB/M/MB/MiB/G/GB/GiB. Default: 100MB.
# thread_usages rows must be `PID TID %CPU TIME` (header `PID` optional). TID may be decimal or hex.
MAX_UPLOAD_BYTES=

# Terminal job retention (Go duration). Default: 1h.
JOB_TTL=

# Max terminal jobs in memory (pending/running never evicted). Default: 200.
JOB_STORE_MAX_SIZE=

# Eviction sweep interval (Go duration). Default: 1m.
JOB_JANITOR_TICK=
