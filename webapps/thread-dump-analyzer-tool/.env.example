# Read by docker compose to populate container environment. Copy to .env and fill in.
# See the README "Run with Docker" section.

# --- Required for the full app (the SPA always signs in through Asgardeo) ---

# Anthropic API key for AI insights (optional; insights are omitted if unset).
ANTHROPIC_API_KEY=

# Asgardeo tenant base URL, e.g. https://api.asgardeo.io/t/<org>. Shared by both services.
ASGARDEO_BASE_URL=

# Asgardeo SPA client ID (public, safe to ship to the browser).
ASGARDEO_CLIENT_ID=

# --- Override these when deploying anywhere other than localhost ---

# Browser-facing backend URL the SPA calls.
# API_URL=https://api.example.com

# Exact browser origin the SPA is served from (must match for CORS).
# CORS_ALLOWED_ORIGINS=https://tdat.example.com

# Host port mappings (the published side of each docker compose port mapping).
# BACKEND_PORT=8080
# FRONTEND_PORT=8081

# Set to false only to exercise the backend API without the SPA (endpoints become public).
# AUTH_ENABLED=true